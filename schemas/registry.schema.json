{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dockyardmods.github.io/the-dockyard/schemas/registry.schema.json",
  "title": "Dockyard Mod Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "version", "currentGameVersionId", "mods"],
  "properties": {
    "$schema": {
      "type": "string",
      "const": "./schemas/registry.schema.json"
    },
    "version": {
      "type": "integer",
      "const": 1
    },
    "currentGameVersionId": {
      "type": "string",
      "minLength": 1
    },
    "mods": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/modEntry"
      }
    }
  },
  "definitions": {
    "certification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["expiresAt"],
      "properties": {
        "expiresAt": {
          "type": "string",
          "format": "date",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        }
      }
    },
    "modEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "repo", "manifestPath", "gameVersionId"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "repo": {
          "type": "string",
          "pattern": "^https://github\\.com/DockyardMods/[A-Za-z0-9_.-]+$"
        },
        "manifestPath": {
          "type": "string",
          "minLength": 1
        },
        "gameVersionId": {
          "type": "string",
          "minLength": 1
        },
        "certification": {
          "$ref": "#/definitions/certification"
        }
      }
    }
  }
}
